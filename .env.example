# =============================================================================
# Creator Campaign OS - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# Required for database-backed pages, actions, and API routes.
# Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Required for authentication.
# Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
# Either key name works. Prefer the current Supabase publishable key if available.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_xxxxx"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."

# Required for file uploads to Supabase Storage.
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# Required in production. Use your deployed URL; localhost is fine for local dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional webhook verification secrets.
SHOPIFY_WEBHOOK_SECRET=""
CONVERSION_WEBHOOK_SECRET=""

# Optional creator portal token secret. Set a strong value in production.
PORTAL_SECRET="change-me"

# Optional AI/search features.
ANTHROPIC_API_KEY="sk-ant-xxxxx"
BRAVE_API_KEY=""
